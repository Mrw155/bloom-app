    <div id="fertileNote" class="range-note" style="display:none; margin-top:14px;"></div>
  </div>

  <!-- DAILY CHECK-IN -->
  <div class="card">
    <span class="section-label">Every day, not just period days</span>
    <h2>Daily check-in</h2>

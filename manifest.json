      <div class="field">
        <label for="flow">Flow</label>
        <select id="flow">
          <option value="">—</option>
          <option value="Light">Light</option>
          <option value="Medium">Medium</option>
          <option value="Heavy">Heavy</option>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="field" style="flex:3;">
        <label for="notes">Symptoms / notes (optional)</label>
        <input type="text" id="notes" placeholder="e.g. cramps, acne, mood swings">
      </div>
    </div>
    <button class="btn-primary" onclick="addEntry()">Save entry</button>
    <span id="saveMsg" style="font-size:12.5px; color:var(--mint); margin-left:12px; font-weight:700;"></span>
  </div>

  <!-- STATS + PREDICTIONS -->
  <div class="card">
    <span class="section-label">Your pattern</span>
    <h2>Cycle overview</h2>

    <div class="cal-legend">
      <span><span class="legend-swatch" style="background:var(--pink-deep);"></span> Period</span>
      <span><span class="legend-swatch" style="background:#fff; border:1.5px dashed var(--gold);"></span> Predicted period</span>
      <span><span class="legend-swatch" style="background:var(--mint-soft);"></span> Fertile window</span>
      <span><span class="legend-swatch" style="background:var(--pink-pale); border:1.5px solid var(--pink-deep);"></span> Today</span>
    </div>
  </div>

  <!-- LOG ENTRY -->
  <div class="card">

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#D6547A">
<meta name="description" content="A private cycle, symptom, and wellbeing tracker.">
<link rel="manifest" href="manifest.json">
<link rel="icon" href="icons/favicon-32.png">
<link rel="apple-touch-icon" href="icons/apple-touch-icon.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Bloom">
<meta name="mobile-web-app-capable" content="yes">
<title>Bloom — cycle &amp; health tracker</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700&family=Nunito:wght@400;500;600;700;800&display=swap');

  :root{
    --pink-deep:#D6547A;
    --pink-mid:#F48FB1;
    --pink-light:#FDE3EC;
    --pink-pale:#FFF6F8;
    --mint:#7FBF95;
    --mint-soft:#E3F3E7;
    --lavender:#A98BC9;
    --lavender-soft:#EEE6F6;
    --sky:#6FA3C9;
    --sky-soft:#E3EFF7;
    --gold:#E0A73B;
    --alert:#E0654F;
    --alert-soft:#FDE6E1;
    --ink:#4A2E38;
    --muted:#9C7C87;
    --line:#F3DCE5;
    --card:#FFFFFF;
    --hero-grad-1:#F48FB1;
    --hero-grad-2:#D6547A;
    --shadow:rgba(214,84,122,0.06);
    color-scheme:light;
  }

  :root[data-theme='dark']{
    --pink-deep:#F2A9C4;
    --pink-mid:#E37FA2;
    --pink-light:#3A2530;
    --pink-pale:#1E1720;
    --mint:#8FD1A2;
    --mint-soft:#264030;
    --lavender:#C3A6E8;
    --lavender-soft:#2E2640;
    --sky:#8FC1E8;
    --sky-soft:#1F3346;
    --gold:#E8BC63;
    --alert:#E88670;
    --alert-soft:#402420;
    --ink:#F3E6EC;
    --muted:#B79AA6;
    --line:#3A2E3D;
    --card:#28202A;
    --hero-grad-1:#5C2C48;
    --hero-grad-2:#2E1826;
    --shadow:rgba(0,0,0,0.25);
    color-scheme:dark;
  }

  @keyframes fadeSlideUp{ from{opacity:0; transform:translateY(16px);} to{opacity:1; transform:translateY(0);} }
  @keyframes fadeSlideDown{ from{opacity:0; transform:translateY(-10px);} to{opacity:1; transform:translateY(0);} }
  @keyframes popIn{ 0%{transform:scale(1);} 45%{transform:scale(1.12);} 100%{transform:scale(1);} }
  @keyframes sunSpin{ from{transform:rotate(0deg);} to{transform:rotate(360deg);} }
  @keyframes sunPulse{ 0%,100%{transform:scale(1); opacity:1;} 50%{transform:scale(1.07); opacity:0.88;} }
  @keyframes floatY{ 0%,100%{transform:translateY(0);} 50%{transform:translateY(-5px);} }
  @keyframes fadeIn{ from{opacity:0;} to{opacity:1;} }

  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--pink-pale);
    color:var(--ink);
    font-family:'Nunito',sans-serif;
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
    padding:0 0 80px 0;
    transition:background-color .25s ease, color .25s ease;
  }
  h1,h2,h3,h4{font-family:'Baloo 2',sans-serif; font-weight:600; margin:0; color:var(--pink-deep);}
  .data{font-family:'Nunito',sans-serif; font-weight:700; letter-spacing:.01em;}

  .wrap{max-width:940px; margin:0 auto; padding:0 20px;}
  .wrap > *{animation:fadeSlideUp .5s ease both;}
  .wrap > *:nth-child(1){animation-delay:.08s;}
  .wrap > *:nth-child(2){animation-delay:.14s;}
  .wrap > *:nth-child(3){animation-delay:.2s;}
  .wrap > *:nth-child(4){animation-delay:.26s;}
  .wrap > *:nth-child(5){animation-delay:.32s;}
  .wrap > *:nth-child(n+6){animation-delay:.36s;}
  .wrap > .cond-card{animation:none;}

  /* THEME SWITCHER */
  .theme-fab{
    position:fixed; top:16px; right:16px; z-index:50;
    width:44px; height:44px; border-radius:50%; background:var(--card); border:1.5px solid var(--line);
    display:flex; align-items:center; justify-content:center; font-size:19px; cursor:pointer;
    box-shadow:0 3px 12px var(--shadow); transition:transform .18s cubic-bezier(.22,.9,.34,1), background-color .2s ease, border-color .2s ease;
  }
  .theme-fab:hover{transform:scale(1.08) rotate(-8deg);}
  .theme-fab:active{transform:scale(0.94);}
  .theme-panel{
    position:fixed; top:66px; right:16px; z-index:50; background:var(--card); border:1.5px solid var(--line);
    border-radius:18px; padding:10px; box-shadow:0 6px 20px var(--shadow); display:none; flex-direction:column; gap:6px;
    min-width:150px; opacity:0; transform:translateY(-8px) scale(0.97); transition:opacity .18s ease, transform .18s ease;
  }
  .theme-panel.open{display:flex; opacity:1; transform:translateY(0) scale(1);}
  .theme-opt{
    display:flex; align-items:center; gap:10px; padding:9px 12px; border-radius:12px; cursor:pointer;
    font-size:13.5px; font-weight:700; color:var(--muted); background:transparent; border:none; width:100%; text-align:left;
    font-family:'Nunito',sans-serif; transition:background-color .15s ease, color .15s ease, transform .12s ease;
  }
  .theme-opt:hover{background:var(--pink-light); transform:translateX(2px);}
  .theme-opt.active{background:var(--pink-deep); color:#fff;}

  /* HERO */
  .hero{
    background:linear-gradient(160deg, var(--hero-grad-1) 0%, var(--hero-grad-2) 100%);
    color:#fff;
    padding:44px 20px 56px 20px;
    border-radius:0 0 36px 36px;
    margin-bottom:28px;
    transition:background .25s ease;
  }
  .hero-inner{max-width:940px; margin:0 auto; display:flex; gap:32px; align-items:center; flex-wrap:wrap;}
  .hero-text{flex:1; min-width:220px; animation:fadeSlideUp .6s ease .05s both;}
  .eyebrow{font-family:'Nunito',sans-serif; font-weight:800; font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:#FFE3ED; opacity:.9; margin-bottom:10px;}
  .hero h1{font-size:clamp(30px,4vw,40px); color:#fff; line-height:1.15;}
  .hero p{color:#FFEAF1; max-width:440px; margin-top:10px; font-size:15px;}

  /* MASCOT */
  .mascot-box{width:200px; height:200px; flex-shrink:0; animation:fadeSlideUp .6s ease .18s both;}
  #mascotSvg{width:100%; height:100%; display:block;}
  #sunRays{transform-origin:110px 72px; animation:sunSpin 60s linear infinite;}
  #sunCore{transform-origin:110px 72px; animation:sunPulse 4s ease-in-out infinite;}
  #mascotBody{animation:floatY 3.6s ease-in-out infinite;}

  /* WHEEL (now inline in Cycle overview card) */
  .wheel-row{display:flex; align-items:center; gap:22px; margin-bottom:18px; flex-wrap:wrap;}
  .wheel-box{position:relative; width:120px; height:120px; flex-shrink:0;}
  #wheelSvg{width:100%; height:100%; display:block;}
  .wheel-center{
    position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
    text-align:center; pointer-events:none;
  }
  .wheel-center .day-num{font-family:'Baloo 2',sans-serif; font-size:22px; font-weight:700; color:var(--pink-deep); display:block;}
  .wheel-center .day-label{font-size:9.5px; color:var(--muted); letter-spacing:.04em; text-transform:uppercase;}
  .wheel-caption{font-size:13px; color:var(--muted); max-width:280px;}

  /* CARDS */
  .card{
    background:var(--card);
    border:1.5px solid var(--line);
    border-radius:24px;
    padding:26px;
    margin-bottom:20px;
    box-shadow:0 2px 14px var(--shadow);
    transition:background-color .25s ease, border-color .25s ease, transform .22s cubic-bezier(.22,.9,.34,1), box-shadow .22s ease;
  }
  .card:hover{ transform:translateY(-3px); box-shadow:0 8px 22px var(--shadow); }
  .card h2{font-size:21px; margin-bottom:4px;}
  .card .sub{color:var(--muted); font-size:13.5px; margin-bottom:18px;}

  .section-label{
    font-family:'Nunito',sans-serif; font-size:11.5px; letter-spacing:.1em; text-transform:uppercase;
    color:var(--pink-mid); display:inline-block; margin-bottom:6px; font-weight:800;
  }

  /* FORM */
  .form-row{display:flex; gap:14px; flex-wrap:wrap; margin-bottom:14px;}
  .field{flex:1; min-width:150px; display:flex; flex-direction:column; gap:6px;}
  .field label{font-size:12.5px; color:var(--muted); font-weight:700;}
  input[type=date], input[type=text], input[type=number], select{
    border:1.5px solid var(--line); border-radius:14px; padding:10px 14px; font-size:14.5px;
    font-family:'Nunito',sans-serif; color:var(--ink); background:var(--pink-pale);
  }
  input:focus, select:focus{outline:none; border-color:var(--pink-mid); background:#fff;}
  button{
    font-family:'Nunito',sans-serif; font-weight:800; font-size:14.5px; border:none; border-radius:999px;
    padding:11px 22px; cursor:pointer; transition:transform .18s cubic-bezier(.22,.9,.34,1), opacity .15s ease, box-shadow .18s ease;
  }
  button:active{transform:scale(0.96);}
  .btn-primary{background:var(--pink-deep); color:#fff;}
  .btn-primary:hover{opacity:.92; transform:translateY(-2px);}
  .btn-secondary{background:var(--pink-light); color:var(--pink-deep);}
  .btn-secondary:hover{opacity:.85; transform:translateY(-2px);}
  .btn-ghost{background:transparent; color:var(--alert); border:1.5px solid var(--alert-soft);}
  .btn-ghost:hover{background:var(--alert-soft);}

  /* STATS ROW */
  .stat-grid{display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:14px; margin-bottom:6px;}
  .stat{background:var(--pink-light); border-radius:18px; padding:16px; animation:fadeSlideUp .4s ease backwards; transition:transform .18s ease;}
  .stat:hover{transform:translateY(-2px);}
  .stat:nth-child(1){animation-delay:.03s;}
  .stat:nth-child(2){animation-delay:.08s;}
  .stat:nth-child(3){animation-delay:.13s;}
  .stat:nth-child(4){animation-delay:.18s;}
  .stat .num{font-family:'Baloo 2',sans-serif; font-size:26px; color:var(--pink-deep); display:block;}
  .stat .lbl{font-size:12px; color:#9A5A72; text-transform:uppercase; letter-spacing:.05em; font-weight:700;}

  /* PREDICTIONS LIST */
  .predict-list{display:flex; flex-direction:column; gap:10px;}
  .predict-item{
    display:flex; justify-content:space-between; align-items:center;
    padding:12px 18px; background:#FFFBF3; border:1.5px dashed var(--gold); border-radius:16px;
    animation:fadeSlideUp .4s ease backwards; transition:transform .18s ease;
  }
  .predict-item:hover{transform:translateY(-2px);}
  .predict-item:nth-child(1){animation-delay:.03s;}
  .predict-item:nth-child(2){animation-delay:.09s;}
  .predict-item:nth-child(3){animation-delay:.15s;}
  .predict-item .p-date{font-weight:800; font-size:14px; color:var(--ink);}
  .predict-item .p-tag{font-size:11.5px; color:var(--gold); text-transform:uppercase; letter-spacing:.05em; font-weight:800;}

  /* HISTORY */
  .history-list{display:flex; flex-direction:column;}
  .history-item{
    display:flex; justify-content:space-between; align-items:center;
    padding:12px 0; border-bottom:1px solid var(--line); animation:fadeIn .35s ease;
    transition:transform .15s ease;
  }
  .history-item:hover{transform:translateX(2px);}
  .history-item:last-child{border-bottom:none;}
  .history-item .h-dates{font-weight:700; font-size:13.5px;}
  .history-item .h-len{font-size:12.5px; color:var(--muted);}
  .del-btn{background:none; border:none; color:var(--muted); cursor:pointer; font-size:13px; padding:4px 10px; font-weight:700; border-radius:8px; transition:color .15s ease, background-color .15s ease, transform .12s ease;}
  .del-btn:hover{color:var(--alert); background:var(--alert-soft); transform:translateY(-1px);}

  .cond-reveal{opacity:0; transform:translateY(-6px); transition:opacity .28s ease, transform .28s ease;}
  .cond-reveal.shown{opacity:1; transform:translateY(0);}

  .empty{color:var(--muted); font-size:14px; padding:10px 0;}

  /* ALERT BANNER */
  .alert-banner{
    background:var(--alert-soft); border:1.5px solid #F3C1B4; border-radius:20px;
    padding:20px; margin-bottom:20px; animation:fadeSlideDown .4s ease;
  }
  .alert-banner h3{color:var(--alert); font-size:16.5px; margin-bottom:8px;}
  .alert-banner p{font-size:14px; color:#6B3B30; margin:0;}

  /* PCOS GUIDANCE */
  .guide-grid{display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:16px; margin-top:16px;}
  .guide-card{background:var(--pink-pale); border-radius:18px; padding:18px; border:1px solid var(--line);}
  .guide-card .g-num{font-family:'Nunito',sans-serif; font-size:12px; color:var(--pink-mid); font-weight:800; margin-bottom:6px; display:block;}
  .guide-card h4{font-family:'Nunito',sans-serif; font-weight:800; font-size:14.5px; margin:0 0 6px 0; color:var(--pink-deep);}
  .guide-card p{font-size:13.5px; color:var(--muted); margin:0;}

  .disclaimer{
    font-size:12.5px; color:var(--muted); background:var(--lavender-soft); border-radius:16px; padding:14px 18px; margin-top:8px;
    border-left:4px solid var(--lavender);
  }

  /* CONDITION TOGGLES */
  .toggle-row{display:flex; gap:12px; flex-wrap:wrap;}
  .toggle-chip{
    display:flex; align-items:center; gap:8px; padding:10px 16px; border-radius:999px;
    border:1.5px solid var(--line); background:var(--pink-pale); cursor:pointer; user-select:none;
    font-weight:700; font-size:13.5px; color:var(--muted); transition:background-color .2s ease, color .2s ease, border-color .2s ease, transform .15s ease;
  }
  .toggle-chip:hover{transform:translateY(-1px);}
  .toggle-chip.active{background:var(--pink-deep); color:#fff; border-color:var(--pink-deep); animation:popIn .3s ease;}
  .toggle-chip input{display:none;}

  /* CONDITION SECTIONS */
  .cond-card{border-left:6px solid var(--pink-mid);}
  .cond-card.diabetes{border-left-color:var(--mint);}
  .cond-card.thyroid{border-left-color:var(--lavender);}
  .cond-card.asthma{border-left-color:var(--sky);}
  .range-note{font-size:12.5px; color:var(--muted); background:var(--pink-pale); border-radius:12px; padding:10px 14px; margin-top:10px;}

  .pill{display:inline-block; padding:3px 10px; border-radius:999px; font-size:11.5px; font-weight:800; text-transform:uppercase; letter-spacing:.03em;}
  .pill.mint{background:var(--mint-soft); color:#3E7A52;}
  .pill.lavender{background:var(--lavender-soft); color:#6B4B92;}
  .pill.sky{background:var(--sky-soft); color:#3E6A8C;}
  .pill.severity-none{background:var(--mint-soft); color:#3E7A52;}
  .pill.severity-mild{background:#FDF3D9; color:#9C7A1E;}
  .pill.severity-moderate{background:#FBE3D0; color:#B25E23;}
  .pill.severity-severe{background:var(--alert-soft); color:#B23A2A;}

  /* PRIVACY BANNER */
  .privacy-banner{
    display:flex; align-items:center; gap:12px; background:var(--mint-soft); border-radius:18px;
    padding:14px 18px; margin-bottom:20px; font-size:13px; color:#3E7A52; font-weight:700;
  }
  .privacy-banner .icon{font-size:20px;}

  /* CALENDAR */
  .cal-header{display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;}
  .cal-nav{display:flex; gap:8px; align-items:center;}
  .cal-nav button{background:var(--pink-light); color:var(--pink-deep); padding:7px 14px; font-size:13px;}
  .cal-month-label{font-family:'Baloo 2',sans-serif; font-weight:700; font-size:17px; color:var(--pink-deep); min-width:150px; text-align:center;}
  .cal-grid{display:grid; grid-template-columns:repeat(7,1fr); gap:6px;}
  .cal-dow{text-align:center; font-size:11px; font-weight:800; color:var(--muted); text-transform:uppercase; padding-bottom:4px;}
  .cal-cell{
    aspect-ratio:1; border-radius:12px; display:flex; flex-direction:column; align-items:center; justify-content:center;
    font-size:12.5px; font-weight:700; color:var(--ink); background:var(--pink-pale); position:relative; border:1.5px solid transparent;
    transition:transform .18s cubic-bezier(.22,.9,.34,1), background-color .2s ease, border-color .2s ease;
  }
  .cal-cell:not(.empty):hover{transform:scale(1.08);}
  .cal-cell.empty{background:transparent;}
  .cal-cell.today{border-color:var(--pink-deep);}
  .cal-cell.period{background:var(--pink-deep); color:#fff;}
  .cal-cell.predicted{background:#fff; border:1.5px dashed var(--gold); color:var(--gold);}
  .cal-cell.fertile{background:var(--mint-soft); color:#3E7A52;}
  .cal-cell.fertile.predicted{background:var(--mint-soft); border:1.5px dashed var(--mint);}
  .cal-dot{position:absolute; bottom:3px; width:4px; height:4px; border-radius:50%; background:var(--lavender);}
  .cal-legend{display:flex; gap:16px; flex-wrap:wrap; margin-top:14px; font-size:12px; color:var(--muted);}
  .cal-legend span{display:inline-flex; align-items:center; gap:6px;}
  .legend-swatch{width:12px; height:12px; border-radius:4px; display:inline-block;}

  /* DAILY LOG */
  .mood-row{display:flex; gap:10px; flex-wrap:wrap; margin-bottom:14px;}
  .mood-opt{
    display:flex; flex-direction:column; align-items:center; gap:4px; padding:10px 14px; border-radius:16px;
    border:1.5px solid var(--line); background:var(--pink-pale); cursor:pointer; font-size:11.5px; font-weight:700; color:var(--muted);
    min-width:64px; transition:background-color .2s ease, color .2s ease, border-color .2s ease, transform .15s ease;
  }
  .mood-opt:hover{transform:translateY(-2px) scale(1.03);}
  .mood-opt.selected{background:var(--pink-deep); color:#fff; border-color:var(--pink-deep); animation:popIn .3s ease;}
  .mood-opt .emoji{font-size:20px; transition:transform .2s ease;}
  .mood-opt:hover .emoji{transform:scale(1.15);}

  /* INSIGHTS */
  .insight-item{
    display:flex; align-items:flex-start; gap:12px; padding:12px 0; border-bottom:1px solid var(--line);
  }
  .insight-item:last-child{border-bottom:none;}
  .insight-icon{font-size:20px; flex-shrink:0;}
  .insight-text{font-size:13.5px; color:var(--ink);}
  .insight-text b{color:var(--pink-deep);}

  footer{text-align:center; color:var(--muted); font-size:12px; margin-top:32px;}

  @media (prefers-reduced-motion: reduce){
    *{transition:none !important; animation:none !important;}
  }
  @media (max-width:480px){
    .hero-inner{flex-direction:column; text-align:center;}
    .hero-text p{margin-left:auto; margin-right:auto;}
  }
</style>
</head>
<body>

<button class="theme-fab" id="themeFab" onclick="toggleThemePanel()" aria-label="Appearance settings">🎨</button>
<div class="theme-panel" id="themePanel">
  <button class="theme-opt" data-pref="light" onclick="setThemePref('light')">☀️ Light</button>
  <button class="theme-opt" data-pref="dark" onclick="setThemePref('dark')">🌙 Dark</button>
  <button class="theme-opt" data-pref="system" onclick="setThemePref('system')">💻 System</button>
</div>

<div class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="eyebrow">Cycle &amp; wellbeing tracker</div>
      <h1>Know your rhythm, gently.</h1>
      <p>Log your periods, check in on how you're feeling, and get a little guidance whenever your body needs extra care.</p>
    </div>
    <div class="mascot-box">
      <svg id="mascotSvg" viewBox="0 0 220 220" aria-hidden="true">
        <!-- sun -->
        <circle id="sunCore" cx="110" cy="72" r="30" fill="#FCD97B"/>
        <g id="sunRays" stroke="#FCD97B" stroke-width="5" stroke-linecap="round">
          <line x1="110" y1="24" x2="110" y2="12"/>
          <line x1="110" y1="120" x2="110" y2="132"/>
          <line x1="62" y1="72" x2="50" y2="72"/>
          <line x1="170" y1="72" x2="158" y2="72"/>
          <line x1="76" y1="38" x2="68" y2="30"/>
          <line x1="144" y1="38" x2="152" y2="30"/>
          <line x1="76" y1="106" x2="68" y2="114"/>
          <line x1="144" y1="106" x2="152" y2="114"/>
        </g>
        <g id="mascotBody">
        <!-- ground shadow -->
        <ellipse cx="110" cy="196" rx="52" ry="8" fill="#F3DCE5"/>
        <!-- body / robe -->
        <path d="M62 188 C62 140 82 120 110 120 C138 120 158 140 158 188 Z" fill="#F48FB1"/>
        <path d="M78 188 C78 152 92 136 110 136 C128 136 142 152 142 188 Z" fill="#FDE3EC"/>
        <!-- crossed legs -->
        <path d="M62 190 Q110 210 158 190 Q110 202 62 190 Z" fill="#D6547A"/>
        <!-- arms resting on knees -->
        <circle cx="66" cy="176" r="9" fill="#F8B6C6"/>
        <circle cx="154" cy="176" r="9" fill="#F8B6C6"/>
        <!-- head -->
        <circle cx="110" cy="98" r="34" fill="#FCD7C5"/>
        <!-- hair bun + strands -->
        <path d="M78 90 C74 60 100 42 110 42 C120 42 146 60 142 90 C142 68 128 54 110 54 C92 54 78 68 78 90 Z" fill="#5A3A3F"/>
        <circle cx="110" cy="40" r="10" fill="#5A3A3F"/>
        <!-- closed smiling eyes -->
        <path d="M96 98 Q100 102 104 98" stroke="#5A3A3F" stroke-width="3" fill="none" stroke-linecap="round"/>
        <path d="M116 98 Q120 102 124 98" stroke="#5A3A3F" stroke-width="3" fill="none" stroke-linecap="round"/>
        <!-- blush -->
        <circle cx="92" cy="108" r="5" fill="#F6A6B8" opacity="0.7"/>
        <circle cx="128" cy="108" r="5" fill="#F6A6B8" opacity="0.7"/>
        <!-- smile -->
        <path d="M101 111 Q110 118 119 111" stroke="#B5556B" stroke-width="3" fill="none" stroke-linecap="round"/>
        </g>
      </svg>
    </div>
  </div>
</div>

<div class="wrap">

  <div class="privacy-banner"><span class="icon">🔒</span> Everything you log stays in your own private storage — no account, no ads, no data shared with anyone.</div>

  <div id="alertZone"></div>

  <!-- CALENDAR -->
  <div class="card">
    <span class="section-label">At a glance</span>
    <h2>Calendar</h2>
    <div class="sub">Solid pink = logged period. Dashed gold = predicted period. Mint = fertile window.</div>
    <div class="cal-header">
      <span class="cal-month-label" id="calMonthLabel"></span>
      <div class="cal-nav">
        <button onclick="shiftMonth(-1)">‹ Prev</button>
        <button onclick="goToday()">Today</button>
        <button onclick="shiftMonth(1)">Next ›</button>
